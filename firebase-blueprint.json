{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "GarmentLine": {
      "title": "Garment Line",
      "description": "A production line in the factory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["name", "userId"]
    },
    "Worker": {
      "title": "Worker",
      "description": "A garment factory worker",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "line": { "type": "string" },
        "performance": { "type": "number" },
        "gender": { "type": "string", "enum": ["nam", "nữ"] },
        "userId": { "type": "string" }
      },
      "required": ["name", "code", "userId"]
    },
    "Operation": {
      "title": "Operation",
      "description": "A sewing operation for a garment",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "style": { "type": "string" },
        "sam": { "type": "number" },
        "targetPerHour": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["name", "code", "userId"]
    },
    "ProductionOrder": {
      "title": "Production Order",
      "description": "A garment manufacturing order",
      "type": "object",
      "properties": {
        "customer": { "type": "string" },
        "styleName": { "type": "string" },
        "job": { "type": "string" },
        "orderQuantity": { "type": "number" },
        "producedQuantity": { "type": "number" },
        "deadline": { "type": "string" },
        "status": { "type": "string", "enum": ["planning", "in_progress", "completed"] },
        "userId": { "type": "string" }
      },
      "required": ["customer", "styleName", "orderQuantity", "userId"]
    },
    "ProductionLog": {
      "title": "Production Log",
      "description": "A log of units produced in an hour",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "line": { "type": "string" },
        "workerId": { "type": "string" },
        "operationId": { "type": "string" },
        "orderId": { "type": "string" },
        "actualQuantity": { "type": "number" },
        "hour": { "type": "number" },
        "targetQuantity": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["date", "orderId", "actualQuantity", "hour", "userId"]
    },
    "TimeStudyRecord": {
      "title": "Time Study Record",
      "description": "A time study recording for an operation",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "workerId": { "type": "string" },
        "operationId": { "type": "string" },
        "style": { "type": "string" },
        "times": { "type": "array", "items": { "type": "number" } },
        "averageTime": { "type": "number" },
        "targetPerHour": { "type": "number" },
        "targetPerDay": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["date", "workerId", "operationId", "style", "times", "userId"]
    },
    "PlanFeedItem": {
      "title": "Plan Feed Item",
      "description": "An uploaded production plan or timeline post with optional graphic layout",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "fileSize": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["title", "userId"]
    },
    "WorkspaceConfig": {
      "title": "Workspace Configuration",
      "description": "Integration configuration including tokens",
      "type": "object",
      "properties": {
        "accessToken": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["accessToken"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "Daily worker attendance log",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "workerId": { "type": "string" },
        "status": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["date", "workerId", "status", "userId"]
    },
    "DutyRecord": {
      "title": "Duty Record",
      "description": "Daily cleaning and waste disposal assignment",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "sweeperIds": { "type": "array", "items": { "type": "string" } },
        "trashCollectorIds": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" }
      },
      "required": ["date", "userId"]
    },
    "WorkerHourlyLog": {
      "title": "Worker Hourly Log",
      "description": "Hourly or daily production log per worker",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "line": { "type": "string" },
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "workerCode": { "type": "string" },
        "opId": { "type": "string" },
        "opCode": { "type": "string" },
        "opName": { "type": "string" },
        "style": { "type": "string" },
        "logType": { "type": "string", "enum": ["daily", "hourly"] },
        "hourRange": { "type": "string" },
        "actualQuantity": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "workerId", "opId", "actualQuantity", "userId"]
    },
    "Meeting": {
      "title": "Meeting",
      "description": "Meeting notes for workers or company",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["worker", "company"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "type", "content", "userId"]
    },
    "QualityLog": {
      "title": "Quality Log",
      "description": "Daily quality check records for sewing operations and workers",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "line": { "type": "string" },
        "workerId": { "type": "string" },
        "operationId": { "type": "string" },
        "totalChecked": { "type": "number" },
        "defectCount": { "type": "number" },
        "defectType": { "type": "string" },
        "severity": { "type": "string", "enum": ["mild", "moderate", "critical"] },
        "notes": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "line", "workerId", "operationId", "totalChecked", "defectCount", "defectType", "severity", "userId"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Global user registry"
    },
    "users/{userId}/config": {
      "schema": "WorkspaceConfig",
      "description": "User's standard and workspace configurations"
    },
    "users/{userId}/lines": {
      "schema": "GarmentLine",
      "description": "User's factory lines"
    },
    "users/{userId}/workers": {
      "schema": "Worker",
      "description": "User's worker database"
    },
    "users/{userId}/operations": {
      "schema": "Operation",
      "description": "User's operation database"
    },
    "users/{userId}/orders": {
      "schema": "ProductionOrder",
      "description": "User's production orders"
    },
    "users/{userId}/productionLogs": {
      "schema": "ProductionLog",
      "description": "User's production records"
    },
    "users/{userId}/timeStudies": {
      "schema": "TimeStudyRecord",
      "description": "User's time study database"
    },
    "users/{userId}/plans": {
      "schema": "PlanFeedItem",
      "description": "User's uploaded production plans and visual charts"
    },
    "users/{userId}/attendance": {
      "schema": "AttendanceRecord",
      "description": "User's worker attendance database"
    },
    "users/{userId}/duties": {
      "schema": "DutyRecord",
      "description": "User's daily cleaning and duty scheduling database"
    },
    "users/{userId}/workerHourlyLogs": {
      "schema": "WorkerHourlyLog",
      "description": "User's worker hourly production logs"
    },
    "users/{userId}/meetings": {
      "schema": "Meeting",
      "description": "User's worker or company meeting notes database"
    },
    "users/{userId}/qualityLogs": {
      "schema": "QualityLog",
      "description": "User's sewing quality check records database"
    }
  }
}
